# What's On — environment variables
# Copy this to .env and fill in real values. .env is gitignored.

# Required for AI tagging (Phase 2) and reviews (Phase 5).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — override the model used for tagging/reviews. Defaults to claude-opus-4-8.
# Set to claude-haiku-4-5 to cut cost if tag quality is good enough.
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional — TMDB poster + streaming-provider lookups. Without it, posters/providers no-op.
# TMDB_API_KEY=

# Optional — Trakt client ID (a working fallback is hardcoded in main.py).
# TRAKT_CLIENT_ID=

# Optional — set to use Postgres instead of local SQLite.
# DATABASE_URL=postgresql://...
# Optional — local SQLite path (defaults to whats_on.db).
# DATABASE_PATH=whats_on.db
